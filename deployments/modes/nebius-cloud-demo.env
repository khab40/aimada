AIMADA_DEPLOYMENT_PROFILE=nebius-cloud-demo
AIMADA_DEPLOYMENT_REAL_NEBIUS=true
AIMADA_DEPLOYMENT_SIMULATED_FALLBACK=true
AIMADA_DEPLOYMENT_LIFECYCLE=simulate,detect,explain,investigate,report,audit,benchmark

COMPOSE_PROJECT_NAME=aimada-nebius-cloud-demo
NEBIUS_ENDPOINT_MODE=local_vllm
NEBIUS_ENDPOINT_NAME=aimada-realtime-investigation-endpoint
NEBIUS_JOB_NAME=aimada-batch-investigation-job
NEBIUS_ENDPOINT_IMAGE=ghcr.io/khab40/ai-market-abuse-detection-arena-endpoint:vllm-qwen-v11
NEBIUS_JOB_IMAGE=ghcr.io/khab40/ai-market-abuse-detection-arena-jobs:artifacts-v3-20260714-151355
NEBIUS_ENDPOINT_AUTH=token
NEBIUS_ENDPOINT_PLATFORM=gpu-l40s-g
NEBIUS_ENDPOINT_PRESET=1gpu-16vcpu-200gb
LOCAL_VLLM_MODEL=Qwen/Qwen2.5-14B-Instruct
LOCAL_VLLM_DTYPE=auto
LOCAL_VLLM_GPU_MEMORY_UTILIZATION=0.90
LOCAL_VLLM_MAX_MODEL_LEN=16384
LOCAL_VLLM_ENABLE_PREFIX_CACHING=true
LOCAL_VLLM_MAX_NUM_SEQS=16
LOCAL_VLLM_TRUST_REMOTE_CODE=true
NEBIUS_REQUEST_TIMEOUT_SECONDS=180
NEBIUS_INFERENCE_TIMEOUT_SECONDS=180
NEBIUS_JOB_RUNS=100
NEBIUS_JOB_BATCH_SIZE=20
NEBIUS_JOB_SCENARIOS=normal_market,spoofing,layering,quote_stuffing
AIMADA_BACKEND_PORT=8000

AIMADA_BUILD_SERVERLESS_IMAGES=true
AIMADA_PUSH_SERVERLESS_IMAGES=false
IMAGE_NAMESPACE=ghcr.io/khab40
TAG=latest
PLATFORM=linux/amd64
