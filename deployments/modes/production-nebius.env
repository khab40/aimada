AIMADA_DEPLOYMENT_PROFILE=production-nebius
AIMADA_DEPLOYMENT_REAL_NEBIUS=true
AIMADA_DEPLOYMENT_SIMULATED_FALLBACK=false
AIMADA_DEPLOYMENT_LIFECYCLE=simulate,detect,explain,investigate,report,audit,benchmark

NEBIUS_ENDPOINT_MODE=nebius
NEBIUS_ENDPOINT_NAME=aimada-prod-realtime-investigation-endpoint
NEBIUS_JOB_NAME=aimada-prod-batch-investigation-job
NEBIUS_ENDPOINT_IMAGE=ghcr.io/khab40/ai-market-abuse-detection-arena-endpoint:latest
NEBIUS_JOB_IMAGE=ghcr.io/khab40/ai-market-abuse-detection-arena-jobs:latest
NEBIUS_ENDPOINT_AUTH=token
NEBIUS_JOB_RUNS=1000
NEBIUS_JOB_BATCH_SIZE=100
NEBIUS_JOB_SCENARIOS=normal_market,spoofing,layering,quote_stuffing,pump_and_cancel

AIMADA_BUILD_SERVERLESS_IMAGES=true
AIMADA_PUSH_SERVERLESS_IMAGES=true
IMAGE_NAMESPACE=ghcr.io/khab40
TAG=latest
PLATFORM=linux/amd64

# Required in production-nebius mode.
AIMADA_OBJECT_STORAGE_URI=
AIMADA_POSTGRES_DSN=
AIMADA_MLFLOW_TRACKING_URI=
AIMADA_OBSERVABILITY_ENDPOINT=
AIMADA_IAM_PROFILE=
AIMADA_SECRETS_BACKEND=

# Optional app-platform hook, for example:
# AIMADA_APP_DEPLOY_COMMAND=terraform -chdir=infra/nebius apply -auto-approve
AIMADA_APP_DEPLOY_COMMAND=
