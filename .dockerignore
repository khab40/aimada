# Root-context images use an allow-list. Everything else (including .git,
# credentials, docs, evidence, outputs, tests, and reproducible assets) stays
# outside the Docker build context.
**

!.dockerignore

!java/
java/**
!java/Dockerfile
!java/build.gradle.kts
!java/settings.gradle.kts
!java/gradlew
!java/gradle/
!java/gradle/**
!java/exchange-proto/
!java/exchange-proto/build.gradle.kts
!java/exchange-proto/src/
!java/exchange-proto/src/main/
!java/exchange-proto/src/main/**
!java/simulation-kernel/
!java/simulation-kernel/build.gradle.kts
!java/simulation-kernel/src/
!java/simulation-kernel/src/main/
!java/simulation-kernel/src/main/**
!java/kernel-benchmarks/
!java/kernel-benchmarks/build.gradle.kts
!java/kernel-grpc/
!java/kernel-grpc/build.gradle.kts
!java/kernel-grpc/src/
!java/kernel-grpc/src/main/
!java/kernel-grpc/src/main/**
!java/control-plane/
!java/control-plane/build.gradle.kts
!java/control-plane/src/
!java/control-plane/src/main/
!java/control-plane/src/main/**

!contracts/
contracts/**
!contracts/proto/
!contracts/proto/**

!backend/
backend/**
!backend/Dockerfile
!backend/compose-entrypoint.sh
!backend/pyproject.toml
!backend/app/
!backend/app/**
# Protobuf bindings and deterministic contract helpers are CI/integration
# tooling; the Python runtime no longer serves or executes the kernel.
backend/app/contracts/**

!agent-runner/
agent-runner/**
!agent-runner/Dockerfile
!agent-runner/app.py
!agent-runner/langgraph_agents.py

!serverless/
serverless/**
!serverless/jobs/
!serverless/jobs/**
