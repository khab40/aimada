# Root-context images use an allow-list. Everything else (including .git,
# credentials, docs, evidence, outputs, tests, and reproducible assets) stays
# outside the Docker build context.
**

!.dockerignore

!backend/
backend/**
!backend/Dockerfile
!backend/pyproject.toml
!backend/app/
!backend/app/**

!agent-runner/
agent-runner/**
!agent-runner/Dockerfile
!agent-runner/app.py
!agent-runner/langgraph_agents.py

!serverless/
serverless/**
!serverless/jobs/
!serverless/jobs/**
