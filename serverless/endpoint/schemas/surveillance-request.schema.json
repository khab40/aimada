{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/khab40/lob-arena/serverless/endpoint/schemas/surveillance-request.schema.json",
  "title": "LOB Arena Summarized Surveillance Episode Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "analysis_type",
    "invocation_reason",
    "simulation_metadata",
    "market_regime",
    "instrument",
    "episode_duration",
    "order_statistics",
    "trade_statistics",
    "derived_market_features",
    "detector_scores",
    "event_timeline",
    "lob_summary",
    "cancellation_metrics",
    "execution_metrics",
    "price_movement"
  ],
  "properties": {
    "schema_version": {"const": "aimada.surveillance.request.v1"},
    "analysis_type": {
      "enum": [
        "high_anomaly",
        "detector_disagreement",
        "completed_episode",
        "simulation_summary",
        "benchmark_generation"
      ]
    },
    "invocation_reason": {"type": "string"},
    "simulation_metadata": {"type": "object"},
    "market_regime": {"type": "object"},
    "instrument": {"type": "object"},
    "episode_duration": {"type": "object"},
    "suspected_agent": {"type": ["object", "null"]},
    "order_statistics": {"type": "object"},
    "trade_statistics": {"type": "object"},
    "derived_market_features": {"type": "object", "maxProperties": 32},
    "detector_scores": {
      "type": "array",
      "maxItems": 16,
      "items": {"$ref": "#/$defs/detector_score"}
    },
    "event_timeline": {
      "type": "array",
      "maxItems": 32,
      "items": {"$ref": "#/$defs/timeline_observation"}
    },
    "lob_summary": {
      "type": "object",
      "description": "Aggregated before/during/after LOB statistics; never raw order-book streams."
    },
    "cancellation_metrics": {"type": "object"},
    "execution_metrics": {"type": "object"},
    "price_movement": {"type": "object"},
    "ground_truth": {"type": ["object", "null"]},
    "previous_agent_behaviour": {
      "type": ["array", "null"],
      "maxItems": 12,
      "items": {"type": "object"}
    },
    "missing_fields": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "detector_score": {
      "type": "object",
      "additionalProperties": false,
      "required": ["detector", "score"],
      "properties": {
        "detector": {"type": "string"},
        "score": {"type": "number", "minimum": 0, "maximum": 1},
        "classification": {"type": ["string", "null"]},
        "alert": {"type": ["boolean", "null"]},
        "severity": {"type": ["string", "null"]}
      }
    },
    "timeline_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "event"],
      "properties": {
        "sequence": {"type": "integer", "minimum": 1},
        "time": {"type": ["string", "integer", "number", "null"]},
        "event": {"type": "string"},
        "agent": {"type": ["string", "null"]},
        "side": {"type": ["string", "null"]},
        "price": {"type": ["number", "null"]},
        "quantity": {"type": ["number", "null"]},
        "stage": {"type": ["string", "null"]}
      }
    }
  }
}
