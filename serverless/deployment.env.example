# Copy values into your local .env or deployment environment.
# Do not commit real tokens.

NEBIUS_TENANT_ID=tenant-e00ek8wmcr5jzwfa9k

# Backend wiring after the Serverless AI Endpoint is deployed.
NEBIUS_ENDPOINT_BASE_URL=http://<endpoint-public-ip>

# Optional explicit per-route overrides.
NEBIUS_INCIDENT_EXPLAINER_URL=
NEBIUS_SCENARIO_GENERATOR_URL=
NEBIUS_ORDERBOOK_ALERT_URL=
NEBIUS_INVESTIGATION_REPORT_URL=

# Optional token used by the backend when calling the endpoint.
ENDPOINT_TOKEN=

# Endpoint runtime mode for Nebius GPU vLLM deployment.
# local_vllm = endpoint starts and calls a local OpenAI-compatible vLLM server.
# mock = deterministic fallback.
NEBIUS_ENDPOINT_MODE=local_vllm
NEBIUS_ENDPOINT_PLATFORM=gpu-h100
NEBIUS_ENDPOINT_PRESET=1gpu-16vcpu-200gb
LOCAL_VLLM_BASE_URL=http://127.0.0.1:8001/v1
LOCAL_VLLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
LOCAL_VLLM_HOST=127.0.0.1
LOCAL_VLLM_PORT=8001
LOCAL_VLLM_GPU_MEMORY_UTILIZATION=0.85
LOCAL_VLLM_MAX_MODEL_LEN=4096

# Backend experiment -> Nebius Serverless Job command adapters.
# Supported template vars: {config_path}, {experiment_id}, {job_id}, {image}, {output_dir}, {subnet_id_arg}, {parent_id_arg}, {volume_arg}
NEBIUS_JOB_IMAGE=ghcr.io/khab40/ai-market-abuse-detection-arena-jobs:artifacts-v2
NEBIUS_JOB_SUBMIT_COMMAND_TEMPLATE=nebius ai job create --async --image {image} --container-command python --args {job_args} --platform cpu-d3 --preset 4vcpu-16gb --disk-size 100Gi --timeout 1h {subnet_id_arg} {parent_id_arg} {volume_arg} --restart-policy never --format json
NEBIUS_JOB_STATUS_COMMAND_TEMPLATE=nebius ai job get {job_id} --format json
NEBIUS_JOB_LOGS_COMMAND_TEMPLATE=nebius ai job logs {job_id}
NEBIUS_JOB_ARTIFACTS_COMMAND_TEMPLATE=
NEBIUS_EVIDENCE_ARCHIVE_ENABLED=true
NEBIUS_JOB_OUTPUT_DIR=/job/outputs/serverless-batch
NEBIUS_JOB_SCENARIOS=normal_market,spoofing,layering,quote_stuffing,pump_and_cancel
