# Copy to .env and fill values. Do not commit real tokens.

NEBIUS_TENANT_ID=

# Backend -> deployed Nebius Serverless AI Endpoint.
# Set this to your created Nebius endpoint base URL. The backend derives:
# - /explain-event
# - /generate-scenario
# - /generate-market-abuse-scenario
# - /orderbook-alert
# - /investigation-report
NEBIUS_ENDPOINT_BASE_URL=

# Optional explicit overrides. Leave empty when NEBIUS_ENDPOINT_BASE_URL is set.
NEBIUS_INCIDENT_EXPLAINER_URL=
NEBIUS_SCENARIO_GENERATOR_URL=
NEBIUS_MARKET_ABUSE_SCENARIO_URL=
NEBIUS_ORDERBOOK_ALERT_URL=
NEBIUS_INVESTIGATION_REPORT_URL=
NEBIUS_INVESTIGATION_TEAM_URL=

# Serverless endpoint runtime.
NEBIUS_ENDPOINT_MODE=mock
NEBIUS_ENDPOINT_PLATFORM=gpu-l40s-g
NEBIUS_ENDPOINT_PRESET=1gpu-16vcpu-200gb
LOCAL_VLLM_MODEL=Qwen/Qwen2.5-14B-Instruct
LOCAL_VLLM_DTYPE=auto
LOCAL_VLLM_GPU_MEMORY_UTILIZATION=0.90
LOCAL_VLLM_MAX_MODEL_LEN=16384
LOCAL_VLLM_ENABLE_PREFIX_CACHING=true
LOCAL_VLLM_MAX_NUM_SEQS=16
LOCAL_VLLM_TRUST_REMOTE_CODE=true
# Professional surveillance output is deterministic; route budgets are 500/1200 tokens.
NEBIUS_PROMPT_SEED=42
NEBIUS_REQUEST_TIMEOUT_SECONDS=180
NEBIUS_INFERENCE_TIMEOUT_SECONDS=180
NEBIUS_HEALTH_TIMEOUT_SECONDS=5
NEBIUS_LOCAL_TOURNAMENT_SCENARIO_LIMIT=24

# Nebius CLI resource creation scripts.
NEBIUS_PARENT_ID=
NEBIUS_SUBNET_ID=
NEBIUS_VOLUME=
NEBIUS_JOB_OUTPUT_VOLUME=
NEBIUS_JOB_OUTPUT_URI=s3://your-nebius-bucket/aimada
NEBIUS_OBJECT_STORAGE_ENDPOINT_URL=https://storage.eu-north1.nebius.cloud
NEBIUS_OBJECT_STORAGE_ACCESS_KEY_ID=
NEBIUS_OBJECT_STORAGE_SECRET_ACCESS_KEY=
NEBIUS_OBJECT_STORAGE_SESSION_TOKEN=
NEBIUS_OBJECT_STORAGE_REGION=eu-north1
NEBIUS_EVIDENCE_ARCHIVE_ENABLED=false
NEBIUS_OBJECT_STORAGE_SERVICE_ACCOUNT_ID=
NEBIUS_OBJECT_STORAGE_ACCESS_KEY_RESOURCE_ID=
NEBIUS_ENDPOINT_IMAGE=ghcr.io/khab40/ai-market-abuse-detection-arena-endpoint:structured-investigation-20260714-02
NEBIUS_JOB_IMAGE=ghcr.io/khab40/ai-market-abuse-detection-arena-jobs:artifacts-v3-20260714-151355
NEBIUS_JOB_SUBMIT_COMMAND_TEMPLATE=
NEBIUS_JOB_STATUS_COMMAND_TEMPLATE=
NEBIUS_JOB_LOGS_COMMAND_TEMPLATE=
NEBIUS_JOB_ARTIFACTS_COMMAND_TEMPLATE=
NEBIUS_JOB_HEALTH_COMMAND=
NEBIUS_CLOUD_PROBE_TIMEOUT_SECONDS=5
NEBIUS_ENDPOINT_AUTH=token
ENDPOINT_TOKEN=
NEBIUS_JOB_RUNS=1000
NEBIUS_JOB_BATCH_SIZE=100
NEBIUS_JOB_OUTPUT_DIR=/job/outputs/serverless-batch
NEBIUS_JOB_SCENARIOS=normal_market,spoofing,layering,quote_stuffing,pump_and_cancel

# Backend runtime.
ARENA_OUTPUT_DIR=../outputs
ARENA_DATA_RETENTION_DAYS=1
ARENA_SAMPLE_DATA_DIR=../data/sample
ARENA_TICK_HISTORY_INTERVAL=10
ARENA_PERSIST_ALL_EVENTS=false
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend runtime.
VITE_API_BASE_URL=http://localhost:8000
VITE_ARENA_MODE=mock
VITE_ARENA_WS_URL=ws://localhost:8000/ws/arena
VITE_ENABLE_GOOGLE_AUTH=false
VITE_ENABLE_ADVANCED_ATTACK_CONTROLS=false
VITE_ENABLE_LEGACY_PAGES=false

# Product surface flags.
ENABLE_GOOGLE_AUTH=false
ENABLE_ADVANCED_ATTACK_CONTROLS=false
ENABLE_LEGACY_PAGES=false

# Google auth. Disabled unless ENABLE_GOOGLE_AUTH and VITE_ENABLE_GOOGLE_AUTH are true.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173
AIMADA_JWT_SECRET=replace-with-a-long-random-secret
AIMADA_JWT_ISSUER=ai-market-abuse-detection-arena
AIMADA_JWT_EXPIRES_IN_SECONDS=43200
# Agent runner runtime.
ARENA_REMOTE_AGENT_URLS=http://agent-runner:9100
AGENT_RUNNER_AGENT_COUNT=24
AGENT_RUNNER_MAX_AGENT_COUNT=48
AGENT_RUNNER_HEAVY_AGENT_COUNT=0
AGENT_RUNNER_MAX_HEAVY_AGENT_COUNT=2
AGENT_RUNNER_HEAVY_AGENT_COMPLEXITY=20000
AGENT_RUNNER_HEAVY_AGENT_WORKERS=1
AGENT_RUNNER_MAX_HEAVY_AGENT_WORKERS=1
AGENT_RUNNER_LANGGRAPH_AGENT_COUNT=0
AGENT_RUNNER_MAX_LANGGRAPH_AGENT_COUNT=4
AGENT_RUNNER_LANGGRAPH_STRATEGY=liquidity_rebalancer
AGENT_RUNNER_AGENT_ID_PREFIX=REMOTE
AGENT_RUNNER_ID=remote
AGENT_RUNNER_DECISION_TIMEOUT_SECONDS=0.05

# Nebius VM app host for backend/frontend/agent-runner.
NEBIUS_VM_HOST=
NEBIUS_VM_USER=ubuntu
NEBIUS_VM_SSH_KEY=~/.ssh/id_ed25519
NEBIUS_VM_APP_DIR=aimada
NEBIUS_VM_BACKEND_PORT=8000
NEBIUS_VM_FRONTEND_PORT=80
NEBIUS_VM_AGENT_RUNNER_REPLICAS=1
NEBIUS_VM_BOOTSTRAP_DOCKER=true
NEBIUS_VM_PUBLIC_BASE_URL=
NEBIUS_VM_API_BASE_URL=
NEBIUS_VM_WS_BASE_URL=
NEBIUS_BACKEND_IMAGE=ghcr.io/your-org/ai-market-abuse-detection-arena-backend:vm-demo
NEBIUS_FRONTEND_IMAGE=ghcr.io/your-org/ai-market-abuse-detection-arena-frontend:vm-demo
NEBIUS_AGENT_RUNNER_IMAGE=ghcr.io/your-org/ai-market-abuse-detection-arena-agent-runner:vm-demo
NEBIUS_VM_CREATE_COMMAND_TEMPLATE=

# Future Kubernetes deployment path.
KUBE_CONTEXT=
K8S_NAMESPACE=aimada
K8S_PUBLIC_ORIGIN=https://aimada.example.com
K8S_API_BASE_URL=https://aimada.example.com
K8S_WS_URL=wss://aimada.example.com/ws/arena
K8S_REMOTE_AGENT_URLS=
K8S_AGENT_RUNNER_REPLICAS=2
K8S_BACKEND_REPLICAS=1
K8S_FRONTEND_REPLICAS=1
K8S_INGRESS_HOST=aimada.example.com
K8S_ENABLE_INGRESS=false
