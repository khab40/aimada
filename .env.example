# Copy to .env and fill values. Do not commit real tokens.

NEBIUS_TENANT_ID=

# Backend -> deployed Nebius Serverless AI Endpoint.
# Set this to your created Nebius endpoint base URL. The backend derives:
# - /explain-event
# - /generate-scenario
# - /orderbook-alert
# - /investigation-report
NEBIUS_ENDPOINT_BASE_URL=

# Optional explicit overrides. Leave empty when NEBIUS_ENDPOINT_BASE_URL is set.
NEBIUS_INCIDENT_EXPLAINER_URL=
NEBIUS_SCENARIO_GENERATOR_URL=
NEBIUS_ORDERBOOK_ALERT_URL=
NEBIUS_INVESTIGATION_REPORT_URL=
NEBIUS_API_KEY=

# Serverless endpoint runtime.
NEBIUS_ENDPOINT_MODE=mock
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
NEBIUS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
# Backward-compatible aliases still supported:
# NEBIUS_AI_STUDIO_BASE_URL=https://api.tokenfactory.nebius.com/v1/
# NEBIUS_AI_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
NEBIUS_TEMPERATURE=0.2
NEBIUS_MAX_TOKENS=800
NEBIUS_REQUEST_TIMEOUT_SECONDS=12

# Nebius CLI resource creation scripts.
NEBIUS_PARENT_ID=
NEBIUS_SUBNET_ID=
NEBIUS_VOLUME=
NEBIUS_ENDPOINT_IMAGE=ghcr.io/your-org/ai-market-abuse-detection-arena-endpoint:latest
NEBIUS_JOB_IMAGE=ghcr.io/your-org/ai-market-abuse-detection-arena-jobs:latest
NEBIUS_ENDPOINT_AUTH=token
NEBIUS_ENDPOINT_TOKEN=
NEBIUS_JOB_RUNS=1000
NEBIUS_JOB_BATCH_SIZE=100

# Backend runtime.
ARENA_OUTPUT_DIR=../outputs
ARENA_SAMPLE_DATA_DIR=../data/sample
LOG_LEVEL=INFO

# Frontend runtime.
VITE_API_BASE_URL=http://localhost:8000
VITE_ARENA_MODE=mock
VITE_ARENA_WS_URL=ws://localhost:8000/ws/arena

# Google auth. Leave empty for local stub login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173
AIMADA_JWT_SECRET=replace-with-a-long-random-secret
AIMADA_JWT_ISSUER=ai-market-abuse-detection-arena
AIMADA_JWT_EXPIRES_IN_SECONDS=43200
# Agent runner runtime.
AGENT_RUNNER_AGENT_COUNT=200
AGENT_RUNNER_HEAVY_AGENT_COUNT=8
AGENT_RUNNER_HEAVY_AGENT_COMPLEXITY=20000
AGENT_RUNNER_HEAVY_AGENT_WORKERS=2
AGENT_RUNNER_LANGGRAPH_AGENT_COUNT=16
AGENT_RUNNER_LANGGRAPH_STRATEGY=liquidity_rebalancer
AGENT_RUNNER_AGENT_ID_PREFIX=REMOTE
AGENT_RUNNER_ID=remote
AGENT_RUNNER_DECISION_TIMEOUT_SECONDS=0.05
