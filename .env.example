# Copy to .env and fill values. Do not commit real tokens.

NEBIUS_TENANT_ID=

# Backend -> deployed Nebius Serverless AI Endpoint.
# Set this to your created Nebius endpoint base URL. The backend derives:
# - /explain-event
# - /generate-scenario
NEBIUS_ENDPOINT_BASE_URL=

# Optional explicit overrides. Leave empty when NEBIUS_ENDPOINT_BASE_URL is set.
NEBIUS_INCIDENT_EXPLAINER_URL=
NEBIUS_SCENARIO_GENERATOR_URL=
NEBIUS_API_KEY=

# Serverless endpoint runtime.
NEBIUS_ENDPOINT_MODE=mock
NEBIUS_AI_STUDIO_BASE_URL=https://api.studio.nebius.com/v1
NEBIUS_AI_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
NEBIUS_TEMPERATURE=0.2
NEBIUS_MAX_TOKENS=800
NEBIUS_REQUEST_TIMEOUT_SECONDS=12

# Backend runtime.
ARENA_OUTPUT_DIR=../outputs
ARENA_SAMPLE_DATA_DIR=../data/sample
LOG_LEVEL=INFO

# Frontend runtime.
VITE_API_BASE_URL=http://localhost:8000
VITE_ARENA_MODE=mock
VITE_ARENA_WS_URL=ws://localhost:8000/ws/arena
